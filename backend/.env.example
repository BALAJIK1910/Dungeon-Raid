# Tech Warzone 2026 Backend Configuration

## Environment Variables Template
# Copy to .env.local and fill in your Firebase project details

# Firebase Project
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Cloud Functions Configuration
FUNCTIONS_MIN_INSTANCES=1
FUNCTIONS_MEMORY=512MB
FUNCTIONS_TIMEOUT=60s
FUNCTIONS_RUNTIME=nodejs20

# Feature Flags
ENABLE_POWERUPS=true
ENABLE_TIME_BONUS=true
ENABLE_HINT_SYSTEM=true

# Logging
DEBUG=techwarzone:*
LOG_LEVEL=info

## Local Emulation
# To use Firebase emulators locally:
# 1. Set FIREBASE_EMULATOR_HOST=127.0.0.1:9000
# 2. Run: firebase emulators:start

FIREBASE_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
