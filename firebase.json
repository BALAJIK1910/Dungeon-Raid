{
    "functions": [
        {
            "source": "backend/functions",
            "codebase": "nodejs",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                ".env"
            ]
        }
    ],
    "firestore": {
        "rules": "backend/firestore-rules/firestore.rules",
        "indexes": "backend/firestore-rules/firestore.indexes.json"
    },
    "hosting": {
        "site": "techwar-6e1d6",
        "public": "frontend/dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "emulators": {
        "auth": {
            "port": 9099
        },
        "firestore": {
            "port": 8080
        },
        "functions": {
            "port": 5001
        },
        "hosting": {
            "port": 5000
        },
        "pubsub": {
            "port": 8085
        },
        "ui": {
            "enabled": true
        }
    }
}
