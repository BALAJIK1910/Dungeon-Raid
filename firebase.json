{
    "functions": [
        {
            "source": "backend/functions",
            "codebase": "nodejs",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                ".env"
            ]
        }
    ],
    "firestore": {
        "rules": "backend/firestore-rules/firestore.rules",
        "indexes": "backend/firestore-rules/firestore.indexes.json"
    },
    "hosting": {
        "site": "techwar-6e1d6",
        "public": "frontend/dist",
        "cleanUrls": true,
        "trailingSlash": false,
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**/*.@(js|css|svg|png|jpg|jpeg|gif|webp|woff2|woff|ttf)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            },
            {
                "source": "index.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            }
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "emulators": {
        "auth": {
            "port": 9099
        },
        "firestore": {
            "port": 8080
        },
        "functions": {
            "port": 5001
        },
        "hosting": {
            "port": 5000
        },
        "pubsub": {
            "port": 8085
        },
        "ui": {
            "enabled": true
        }
    }
}
